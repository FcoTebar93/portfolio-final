---
import { t } from '../utils/i18n.ts';

const projects = [
  {
    id: "eventix",
    tech: ["Next.js", "TypeScript", "PostgreSQL", "Stripe", "Tailwind CSS"],
    githubUrl: "https://github.com/FcoTebar93/Eventix",
    liveUrl: "#",
  },
  {
    id: "agentic-code-reviewer",
    tech: [
      "Python",
      "FastAPI",
      "React",
      "TypeScript",
      "Vite",
      "Tailwind",
      "Docker / Docker Compose",
      "PostgreSQL",
      "RabbitMQ",
      "Redis",
      "Qdrant",
    ],
    githubUrl: "https://github.com/FcoTebar93/Agentic-Code-Reviewer",
    liveUrl: "#",
  },
  {
    id: "ftn",
    tech: [
      "TypeScript",
      "Node.js",
      "Preact",
      "Vite",
      "PostgreSQL",
      "Docker + Docker Compose",
      "Stripe API",
      "SendGrid API",
    ],
    githubUrl: "https://github.com/FcoTebar93/FTN",
    liveUrl: "#",
  },
];
---

<section id="projects" class="px-4 py-16 sm:py-24 bg-secondary/40">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-baseline justify-between gap-4 mb-10 sm:mb-14">
        <div>
          <p
            class="text-xs sm:text-sm uppercase tracking-[0.2em] text-accent font-mono mb-2"
            data-i18n="projects.title"
          >
            {t('projects.title')}
          </p>
          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-semibold tracking-tight"
            data-i18n="projects.subtitle"
          >
            {t('projects.subtitle')}
          </h2>
        </div>
      </div>

    <div class="grid gap-6 md:gap-8 md:grid-cols-3">
      {projects.map((project, columnIndex) => (
        <article
          class="project-card group cursor-pointer rounded-2xl border border-accent/15 bg-secondary overflow-hidden flex flex-col hover:border-accent hover:shadow-xl transition-all duration-300"
          data-project-id={project.id}
          data-modal-enter-col={columnIndex}
          style={`--card-enter-order:${projects.length - 1 - columnIndex};`}
          data-name={t(`projects.items.${project.id}.name`)}
          data-role={t(`projects.items.${project.id}.role`)}
          data-short={t(`projects.items.${project.id}.short`)}
          data-long={t(`projects.items.${project.id}.long`)}
          data-github-url={project.githubUrl}
          data-live-url={project.liveUrl}
          data-tech={JSON.stringify(project.tech)}
        >
          <div class="relative h-40 sm:h-44 bg-gradient-to-br from-accent/20 via-primary to-accent/10 flex items-center justify-center">
            <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-accent/90 text-primary font-mono font-bold text-xl flex items-center justify-center shadow-lg">
              {t(`projects.items.${project.id}.name`).slice(0, 2).toUpperCase()}
            </div>
            <div class="absolute inset-0 opacity-40 mix-blend-screen pointer-events-none project-card-glow" />
          </div>

          <div class="flex-1 flex flex-col p-5 sm:p-6 gap-4">
            <div>
              <p
                class="text-[0.7rem] uppercase tracking-[0.18em] text-accent font-mono mb-1"
                data-i18n={`projects.items.${project.id}.role`}
              >
                {t(`projects.items.${project.id}.role`)}
              </p>
              <h3
                class="text-lg sm:text-xl font-semibold mb-1 group-hover:text-accent transition-colors"
                data-i18n={`projects.items.${project.id}.name`}
              >
                {t(`projects.items.${project.id}.name`)}
              </h3>
              <p
                class="text-sm text-muted line-clamp-3"
                data-i18n={`projects.items.${project.id}.short`}
              >
                {t(`projects.items.${project.id}.short`)}
              </p>
            </div>

            <div class="flex flex-wrap gap-1.5 mt-1">
              {project.tech.map((tag) => (
                <span class="tag">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

  <div
    id="project-modal"
    class="fixed inset-0 z-40 hidden flex items-center justify-center px-4 py-8 bg-black/60 backdrop-blur-sm project-modal"
    role="dialog"
    aria-modal="true"
    aria-label={t('projects.ui.cardModalLabel')}
    aria-hidden="true"
  >
    <div class="relative max-w-3xl w-full bg-secondary rounded-2xl border border-accent/25 shadow-2xl overflow-hidden modal-content">
      <div class="grid md:grid-cols-[1.1fr,0.9fr]">
        <div class="relative bg-gradient-to-br from-accent/20 via-primary to-accent/10 p-8 flex flex-col justify-end">
          <div class="absolute inset-0 opacity-50 pointer-events-none project-card-glow" />
          <div class="relative z-10">
            <p class="text-[0.7rem] uppercase tracking-[0.18em] text-accent font-mono mb-2" id="project-modal-role">
            </p>
            <h3 class="text-2xl font-semibold mb-2" id="project-modal-title">
            </h3>
            <p class="text-sm text-muted max-w-md" id="project-modal-short">
            </p>
          </div>
        </div>

        <div class="p-6 sm:p-7 flex flex-col gap-4">
          <div class="space-y-2">
            <h4
              class="text-sm font-semibold text-accent tracking-[0.18em] uppercase"
              data-i18n="projects.ui.modalDetails"
            >
              {t('projects.ui.modalDetails')}
            </h4>
            <p class="text-sm text-muted leading-relaxed" id="project-modal-long">
            </p>
          </div>

          <div>
            <h4
              class="text-xs font-semibold text-muted/80 tracking-[0.22em] uppercase mb-2"
              data-i18n="projects.ui.modalTechnologies"
            >
              {t('projects.ui.modalTechnologies')}
            </h4>
            <div class="flex flex-wrap gap-1.5" id="project-modal-tags">
            </div>
          </div>

          <div class="mt-4 flex flex-wrap justify-end gap-3">
            <a
              href="#"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center px-4 py-2 rounded-full bg-accent text-primary text-xs sm:text-sm font-semibold hover:opacity-90 transition-all hover:shadow-md hover:scale-[1.02] active:scale-[0.98]"
              id="project-modal-github"
              data-i18n="projects.ui.modalGithub"
            >
              {t('projects.ui.modalGithub')}
            </a>
            <a
              href="#"
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center px-4 py-2 rounded-full bg-primary text-muted text-xs sm:text-sm font-semibold border border-accent/40 hover:border-accent hover:text-accent transition-all hover:shadow-md hover:scale-[1.02] active:scale-[0.98]"
              id="project-modal-live"
              data-i18n="projects.ui.modalLive"
            >
              {t('projects.ui.modalLive')}
            </a>
            <button
              type="button"
              id="project-modal-close"
              class="inline-flex items-center justify-center px-4 py-2 rounded-full bg-secondary text-muted text-xs sm:text-sm font-semibold border border-accent/40 hover:border-accent hover:text-accent hover:bg-primary/60 cursor-pointer transition-all hover:shadow-md hover:scale-[1.02] active:scale-[0.98]"
              data-i18n="projects.ui.modalBack"
            >
              {t('projects.ui.modalBack')}
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var modal = document.getElementById("project-modal");
      if (!modal) return;

      var titleEl = document.getElementById("project-modal-title");
      var roleEl = document.getElementById("project-modal-role");
      var shortEl = document.getElementById("project-modal-short");
      var longEl = document.getElementById("project-modal-long");
      var tagsEl = document.getElementById("project-modal-tags");
      var githubEl = document.getElementById("project-modal-github");
      var liveEl = document.getElementById("project-modal-live");

      function openModal(cardEl) {
        if (!cardEl) return;

        var projectId = cardEl.getAttribute("data-project-id");
        var tFn = (window && window.t) ? window.t : function (k) { return k; };

        if (projectId) {
          modal.setAttribute("data-active-project-id", projectId);
          if (titleEl) titleEl.textContent = tFn("projects.items." + projectId + ".name");
          if (roleEl) roleEl.textContent = tFn("projects.items." + projectId + ".role");
          if (shortEl) shortEl.textContent = tFn("projects.items." + projectId + ".short");
          if (longEl) longEl.textContent = tFn("projects.items." + projectId + ".long");
        }

        if (tagsEl) {
          tagsEl.innerHTML = "";
          var techRaw = cardEl.getAttribute("data-tech") || "[]";
          var techList;
          try {
            techList = JSON.parse(techRaw);
          } catch (e) {
            techList = techRaw.split(",").map(function (s) { return s.trim(); });
          }
          if (Array.isArray(techList)) {
            techList.forEach(function (tag) {
              var span = document.createElement("span");
              span.className = "tag";
              span.textContent = tag;
              tagsEl.appendChild(span);
            });
          }
        }

        if (githubEl) {
          githubEl.href = cardEl.getAttribute("data-github-url") || "#";
        }
        if (liveEl) {
          liveEl.href = cardEl.getAttribute("data-live-url") || "#";
        }

        var enterCol = cardEl.getAttribute("data-modal-enter-col");
        if (enterCol === "0" || enterCol === "1" || enterCol === "2") {
          modal.setAttribute("data-enter-col", enterCol);
        } else {
          modal.removeAttribute("data-enter-col");
        }

        modal.classList.remove("hidden");
        modal.classList.remove("is-open");
        void modal.offsetWidth;
        modal.classList.add("is-open");
        modal.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
      }

      function closeModal() {
        modal.removeAttribute("data-active-project-id");
        modal.removeAttribute("data-enter-col");
        modal.classList.add("hidden");
        modal.classList.remove("is-open");
        modal.setAttribute("aria-hidden", "true");
        document.body.style.overflow = "";
      }

      document.querySelectorAll("[data-project-id]").forEach(function (card) {
        card.addEventListener("click", function () {
          openModal(card);
        });
      });

      document.getElementById("project-modal-close")?.addEventListener("click", closeModal);

      document.addEventListener("keydown", function (event) {
        if (event.key === "Escape" && !modal.classList.contains("hidden")) {
          closeModal();
        }
      });
    })();
  </script>

  <style>
    .project-card-glow {
      background:
        radial-gradient(circle at 10% 0%, rgba(56, 189, 248, 0.8), transparent 50%),
        radial-gradient(circle at 90% 100%, rgba(59, 130, 246, 0.7), transparent 55%);
    }

    /* Entrada de cards: de derecha a izquierda, una a una */
    .project-card {
      opacity: 0;
      transform: translate(72px, 0) scale(0.98);
      animation: project-card-enter 0.54s cubic-bezier(0.22, 0.88, 0.3, 1) forwards;
      animation-delay: calc(120ms + (var(--card-enter-order, 0) * 130ms));
      will-change: transform, opacity;
    }

    @keyframes project-card-enter {
      from {
        opacity: 0;
        transform: translate(72px, 0) scale(0.98);
      }
      to {
        opacity: 1;
        transform: translate(0, 0) scale(1);
      }
    }

    :global(.tag) {
      background: var(--color-primary);
      color: var(--color-accent);
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      font-size: 0.75rem;
      font-family: var(--font-mono);
      border: 1px solid rgba(56, 189, 248, 0.28);
      transition: all 0.18s ease;
    }

    :global(.tag):hover {
      border-color: var(--color-accent);
      background: rgba(56, 189, 248, 0.12);
    }

    .modal-content {
      max-height: min(90vh, 640px);
    }

    .project-modal {
      --modal-start-x: min(28vw, 140px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.34s ease-out;
    }

    .project-modal.is-open {
      opacity: 1;
      pointer-events: auto;
    }

    /* Entrada desde la derecha: tarjeta izquierda (col 0) recorre más; la derecha (col 2), menos */
    .project-modal .modal-content {
      transform: translate(0, 0) scale(1);
    }

    .project-modal[data-enter-col="0"] {
      --modal-start-x: min(88vw, 520px);
    }

    .project-modal[data-enter-col="1"] {
      --modal-start-x: min(56vw, 320px);
    }

    .project-modal[data-enter-col="2"] {
      --modal-start-x: min(30vw, 160px);
    }

    .project-modal.is-open .modal-content {
      animation: project-modal-enter 0.46s cubic-bezier(0.22, 0.88, 0.3, 1) both;
    }

    @keyframes project-modal-enter {
      from {
        transform: translate(var(--modal-start-x), 12px) scale(0.97);
      }
      to {
        transform: translate(0, 0) scale(1);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .project-card {
        opacity: 1 !important;
        transform: none !important;
        animation: none !important;
      }

      .project-modal .modal-content {
        transform: translate(0, 0) scale(1) !important;
        animation: none !important;
      }

      .project-modal {
        transition-duration: 0.01ms !important;
      }
    }

    @media (max-width: 768px) {
      .modal-content {
        max-height: 90vh;
      }
    }

    [data-theme="light"] #projects {
      background: var(--color-secondary);
    }

    [data-theme="light"] .project-card {
      background: var(--color-surface);
      border-color: var(--color-border);
    }

    [data-theme="light"] .project-card:hover {
      border-color: var(--color-accent);
      box-shadow: 0 10px 30px rgba(2, 132, 199, 0.18);
    }

    [data-theme="light"] #project-modal .modal-content {
      background: var(--color-surface);
      border-color: var(--color-border-strong, var(--color-accent));
    }
  </style>
</section>

